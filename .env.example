NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Free production defaults (no paid APIs required) ──────────────────────────

# Block Apollo, Hunter, OpenAI, etc. Default: true (free scraping stack only).
DISABLE_PAID_APIS=true

# Company discovery (step 1): scraping | apify | companies-house (UK only) | mock
# Works for any country when using scraping + SearXNG — not limited to US/UK.
COMPANY_DATA_PROVIDER=scraping

# People discovery (step 2): pdl | scraping | apollo | mock
# When PEOPLE_DATA_LABS_API_KEY is set, step 2 uses People Data Labs automatically.
CONTACT_DISCOVERY_PROVIDER=pdl
# Get key: https://www.peopledatalabs.com/
PEOPLE_DATA_LABS_API_KEY=

# Apify — optional paid add-on (Google Maps + website crawler). Off by default.
# Get token: https://console.apify.com/account/integrations
# Requires DISABLE_PAID_APIS=false and APIFY_ENABLED=true
APIFY_API_TOKEN=
APIFY_ENABLED=false
# Actors (owner/name — converted automatically for API calls)
APIFY_GOOGLE_MAPS_ACTOR=compass/crawler-google-places
APIFY_WEBSITE_CRAWLER_ACTOR=apify/website-content-crawler
APIFY_MAX_PLACES_PER_SEARCH=25
APIFY_RUN_TIMEOUT_SEC=120

# UK Companies House API key (free) — https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# ── Apollo/Clay-style free pipeline (priority order) ───────────────────────────
# 🥇 Search scraping     → SearXNG + Brave (docker compose up searxng)
# 🥈 Website scraping    → Cheerio + Playwright + optional AI (OPENROUTER_API_KEY)
# 🥉 Profile discovery   → LinkedIn profile search + scrape via SearXNG (+ Playwright for profile pages)
# 🏅 Email + verify      → OpenRouter outreach drafts + DNS/SMTP verification

# Self-hosted SearXNG — tier 🥇 primary company/people search
# Local dev: http://localhost:8080  |  Docker: http://searxng:8080
SEARXNG_URL=http://localhost:8080

# Free global company directory seeds (merged before web scraping)
COMPANY_DIRECTORY_ENABLED=true
# Hotfrog, Manta, Brownbook, Cylex, Kompass, Clutch, Chamber, GoodFirms, Europages (requires SEARXNG_URL)
BUSINESS_DIRECTORY_ENABLED=true
# Crunchbase + Wellfound public profile pages (requires SEARXNG_URL)
PUBLIC_DATABASE_ENABLED=true
# Guess john@ / john.smith@ patterns when website has no email (verified in step 4)
EMAIL_PATTERN_GUESS_ENABLED=false

# Recommended: Google Places API (Google Maps) — $200/month free credit (~thousands of searches)
# 1. https://console.cloud.google.com/ → create project → enable "Places API (New)"
# 2. APIs & Services → Credentials → Create API key
# Used for company discovery via Google Maps business listings (primary when set).
GOOGLE_PLACES_API_KEY=
# Alias for GOOGLE_PLACES_API_KEY
GOOGLE_MAPS_API_KEY=
# Set false to disable Google Maps directory seeds while keeping the key for other uses
GOOGLE_MAPS_DIRECTORY_ENABLED=true

# Free OpenStreetMap business directory (Overpass API — no key required)
OVERPASS_DIRECTORY_ENABLED=true
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Optional: official registries (requires business email at opencorporates.com)
OPEN_CORPORATES_API_TOKEN=

# Playwright headless browser — tier 🥈 website scraping
# Run once after install: npx playwright install chromium
SCRAPING_PLAYWRIGHT_ENABLED=true

# AI extraction on team pages when Cheerio/Playwright find nothing (tier 🥈)
# Requires free OPENROUTER_API_KEY — uses llama-3.1-8b-instruct:free by default
SCRAPING_AI_EXTRACTION_ENABLED=true

# Redis for async scraping jobs (optional)
REDIS_URL=

# Supabase service role — required for background worker persistence
SUPABASE_SERVICE_ROLE_KEY=

# Email verification: dns (free MX lookup) | mock — tier 🏅
# (hunter is disabled when DISABLE_PAID_APIS=true)
EMAIL_VERIFICATION_PROVIDER=dns
# SMTP RCPT TO check after DNS (safe mode — no email sent). Set false to skip.
EMAIL_SMTP_VERIFY_ENABLED=true

# Email generation: mock | openrouter (free models) — tier 🏅 outreach copy
# openai is disabled when DISABLE_PAID_APIS=true
EMAIL_GENERATION_PROVIDER=mock

# Free OpenRouter key — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Email sending: gmail (free OAuth) | outlook | mock
EMAIL_SENDING_PROVIDER=gmail

# Reply tracking: defaults to connected Gmail/Outlook account
REPLY_TRACKING_PROVIDER=

# Google OAuth — same credentials as Supabase Google provider
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Paid lead-data APIs — not used when DISABLE_PAID_APIS=true (default)
# APOLLO_API_KEY=
# HUNTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common

# Logging: debug | info | warn | error
LOG_LEVEL=info
