NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Company discovery provider: mock | apollo
COMPANY_DATA_PROVIDER=mock

# Apollo.io Master API key — required when COMPANY_DATA_PROVIDER=apollo.
# Organization search (/mixed_companies/search) needs a paid Apollo plan;
# free plans and trials return 403 (API_INACCESSIBLE).
APOLLO_API_KEY=your_apollo_api_key

# Email verification provider: mock | hunter
EMAIL_VERIFICATION_PROVIDER=mock

# Hunter.io API key — required when EMAIL_VERIFICATION_PROVIDER=hunter
HUNTER_API_KEY=your_hunter_api_key

# Email generation provider: mock | openai
EMAIL_GENERATION_PROVIDER=mock

# OpenAI API key — required when EMAIL_GENERATION_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key

# Optional OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Gmail sending provider: mock | gmail
GMAIL_SENDING_PROVIDER=mock

# Google OAuth credentials — required when GMAIL_SENDING_PROVIDER=gmail
# Use the same Client ID/Secret from your Supabase Google provider config
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
