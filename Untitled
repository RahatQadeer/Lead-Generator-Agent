# Email sending provider: mock | gmail | outlook
EMAIL_SENDING_PROVIDER=mock

# Legacy alias for EMAIL_SENDING_PROVIDER (still supported)
GMAIL_SENDING_PROVIDER=mock

# Google OAuth credentials — required when EMAIL_SENDING_PROVIDER=gmail
# Use the same Client ID/Secret from your Supabase Google provider config
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth credentials — required when EMAIL_SENDING_PROVIDER=outlook
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Optional Microsoft tenant (default: common)
MICROSOFT_TENANT_ID=common
